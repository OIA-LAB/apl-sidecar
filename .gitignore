__pycache__/
*.pyc
.pytest_cache/
# virtualenvs — never committed
.venv/
venv/
# relicensing scratch (license originals + write smoke); never committed
_licfetch/
# local demo signing keys — NEVER committed
keys/
*.pem
# ...but the repo demo PUBLIC verification key must ship with the repo
# (fresh clones need it to verify the committed receipts; public key only,
# CI-checked by tests/test_no_deprecated_terms.py)
!spec/*.pem
# frozen v0.1.0 conformance vectors ship the demo PUBLIC key too
!spec/conformance/**/*.pem
