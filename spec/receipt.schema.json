{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/OIA-LAB/apl-sidecar/spec/receipt.schema.json",
  "title": "APL Task Egress Receipt v0.2.0-draft (additive; v0.1 receipts remain valid)",
  "type": "object",
  "required": [
    "run_id",
    "task_type",
    "policy_id",
    "provider_events",
    "local_only_hashes",
    "single_provider_exposure",
    "max_single_provider_exposure",
    "no_single_provider_saw_full",
    "prev_receipt_hash",
    "receipt_hash",
    "signature",
    "signing_key_id",
    "masking_level",
    "provenance"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "task_type": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]{1,63}$"
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "provider_id",
          "payload_sha256",
          "payload_chars",
          "response_sha256",
          "event_type"
        ],
        "properties": {
          "provider_id": {
            "type": "string",
            "minLength": 1
          },
          "payload_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "payload_chars": {
            "type": "integer",
            "minimum": 0
          },
          "response_sha256": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              {
                "type": "null"
              }
            ]
          },
          "event_type": {
            "type": "string",
            "enum": [
              "mock_response",
              "live_response",
              "no_response"
            ]
          },
          "seat_id": {
            "type": "string",
            "minLength": 1
          },
          "provider_kind": {
            "type": "string",
            "enum": [
              "anthropic",
              "openai"
            ]
          },
          "trust_domain": {
            "type": "string",
            "minLength": 1
          },
          "endpoint_host": {
            "type": "string",
            "minLength": 1
          },
          "model": {
            "type": "string",
            "minLength": 1
          },
          "response_chars": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 0
              },
              {
                "type": "null"
              }
            ]
          },
          "response_truncated": {
            "type": "boolean"
          },
          "completion": {
            "type": "string",
            "enum": [
              "complete",
              "truncated",
              "unknown"
            ]
          },
          "usage": {
            "type": "object"
          }
        }
      }
    },
    "local_only_hashes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "field",
          "sha256"
        ],
        "properties": {
          "field": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "single_provider_exposure": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "provider_id",
          "exposure_ratio"
        ],
        "properties": {
          "provider_id": {
            "type": "string",
            "minLength": 1
          },
          "exposure_ratio": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    },
    "max_single_provider_exposure": {
      "type": "number",
      "minimum": 0
    },
    "no_single_provider_saw_full": {
      "type": "boolean"
    },
    "prev_receipt_hash": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "receipt_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "signature": {
      "type": "object",
      "required": [
        "alg",
        "value"
      ],
      "properties": {
        "alg": {
          "type": "string",
          "const": "Ed25519"
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "signing_key_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9._-]{1,64}$"
    },
    "masking_level": {
      "type": "string",
      "enum": [
        "guided_curated_p0"
      ]
    },
    "provenance": {
      "type": "object",
      "required": [
        "apl_sidecar_version",
        "receipt_schema_version",
        "policy_version",
        "example_id",
        "created_at"
      ],
      "properties": {
        "apl_sidecar_version": {
          "type": "string"
        },
        "receipt_schema_version": {
          "type": "string"
        },
        "policy_version": {
          "type": "string"
        },
        "example_id": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        }
      }
    },
    "max_single_seat_exposure": {
      "type": "number",
      "minimum": 0
    },
    "max_single_trust_domain_exposure": {
      "type": "number",
      "minimum": 0
    },
    "no_single_trust_domain_received_all_fragments": {
      "type": "boolean"
    },
    "trust_domain_exposure": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "trust_domain",
          "exposure_ratio",
          "seat_ids"
        ],
        "properties": {
          "trust_domain": {
            "type": "string",
            "minLength": 1
          },
          "exposure_ratio": {
            "type": "number",
            "minimum": 0
          },
          "seat_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
