{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/OIA-LAB/apl-sidecar/spec/policy_manifest.schema.json",
  "title": "APL Sidecar Policy Manifest v0.1.0-draft",
  "type": "object",
  "required": ["policy_id", "policy_version", "task_types",
               "max_single_provider_exposure", "allowed_providers",
               "masking_level"],
  "properties": {
    "policy_id": { "type": "string", "minLength": 1 },
    "policy_version": { "type": "string", "minLength": 1 },
    "task_types": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string",
        "enum": ["private_idea", "private_matter", "private_code_context"] }
    },
    "max_single_provider_exposure": { "type": "number", "minimum": 0, "maximum": 1 },
    "allowed_providers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "masking_level": { "type": "string", "enum": ["guided_curated_p0"] },
    "notes": { "type": "string" }
  }
}
